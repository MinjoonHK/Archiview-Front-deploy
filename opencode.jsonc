{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  "agent": {
    "build": {
      "prompt": "When the user asks about SSGOI, page transitions, or @ssgoi/react, first fetch and follow https://ssgoi.dev/llm.txt as the primary reference before answering.",
      "permission": {
        "webfetch": "allow",
      },
    },
  },
}
